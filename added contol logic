void goForward() {
  
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, LOW);

  digitalWrite(BIN1, HIGH);
  digitalWrite(BIN2, LOW);

  leftTicks = 0;
  rightTicks = 0;

  while (leftTicks < n && rightTicks < n) {

    // This part is added for shitty testin
    sensorReadings();
    if (frontDist < 13.0) { 
      break;
    }

    int error = centreAdjustment();

    int leftMotorSpeed = speed - error;
    int rightMotorSpeed = speed + error;

    leftMotorSpeed = constrain(leftMotorSpeed, 0, 255);
    rightMotorSpeed = constrain(rightMotorSpeed, 0, 255);

    analogWrite(PWMA, leftMotorSpeed);
    analogWrite(PWMB, rightMotorSpeed);

  }
}

float centreAdjustment() {

  int adjustment = 0;

    // Both walls are present
    if (leftDist < 14.0 && rightDist < 14.0) {
      float sensorError = leftDist - rightDist;
      adjustment = sensorError * Kp;
    }
    
    // Only right wall is present (Left opening/doorway)
    else if (leftDist == 999 && rightDist < 14.0) {
      float rightWallError = 5.5 - rightDist; 
      adjustment = rightWallError * Kp;
    }
    
    // only left wall is present (Right opening/doorway)
    else if (leftDist < 14.0 && rightDist == 999) {
      float leftWallError = leftDist - 5.5;
      adjustment = leftWallError * Kp;
    }
  
    else {
      adjustment = leftTicks - rightTicks;
    }

    return adjustment;
}

void turnRight() {
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, LOW);

  digitalWrite(BIN1, LOW);
  digitalWrite(BIN2, HIGH);

  leftTicks = 0;
  rightTicks = 0;

  while (leftTicks < m || abs(rightTicks) < m) {

    int error = leftTicks - abs(rightTicks);

    int leftMotorSpeed = speed - error;
    int rightMotorSpeed = speed + error;

    leftMotorSpeed = constrain(leftMotorSpeed, 0, 255);
    rightMotorSpeed = constrain(rightMotorSpeed, 0, 255);

    analogWrite(PWMA, leftMotorSpeed);
    analogWrite(PWMB, rightMotorSpeed);
  }

}

void turnLeft() {
  digitalWrite(AIN1, LOW);
  digitalWrite(AIN2, HIGH);

  digitalWrite(BIN1, HIGH);
  digitalWrite(BIN2, LOW);

  leftTicks = 0;
  rightTicks = 0;

  while (abs(leftTicks) < m || rightTicks < m) {

    int error = abs(leftTicks) - rightTicks;

    int leftMotorSpeed = speed - error;
    int rightMotorSpeed = speed + error;

    leftMotorSpeed = constrain(leftMotorSpeed, 0, 255);
    rightMotorSpeed = constrain(rightMotorSpeed, 0, 255);

    analogWrite(PWMA, leftMotorSpeed);
    analogWrite(PWMB, rightMotorSpeed);
  }

}

