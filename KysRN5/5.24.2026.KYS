#include <SharpDistSensor.h>
#include <Wire.h>
#include <MPU6050.h>

// determine pins

// when robot is in centre the values for left and right sharp irs are 5.5 cm assuming a cell is 18cm x 18cm

// left motor
const int PWMA = 5;
const int AIN1 = 7;
const int AIN2 = 8;
// left motor encoder
const int leftEncoderPhaseA = 2; // hardware interrupt 0
const int leftEncoderPhaseB = 4; // direction logic 

// right motor
const int PWMB = 6;
const int BIN1 = 9;
const int BIN2 = 10;
// right motor encoder
const int rightEncoderPhaseA = 3;
const int rightEncoderPhaseB = 11;

// pwm signal speed for motors
const int speed = 60;

// encoder ticks
volatile long leftTicks = 0;
volatile long rightTicks = 0;

// sharp IR
SharpDistSensor sensorFront(A0, 5);
SharpDistSensor sensorLeft(A2, 5);
SharpDistSensor sensorRight(A1, 5);

// control system
// PID Control System
const float Kp = 10.5; 
const float Ki = 0.05; // Keep this VERY small to start!
const float Kd = 2.0;  // Usually larger than Ki, helps dampen wobbles

// Memory variables for PID
float integralError = 0.0;
float previousError = 0.0;

// adjust 
const float calibrateStep = 10;
const float smallAdjustment = 5;

//----- Gyro
MPU6050 mpu;
float angleZ       = 0;
float gyroZ_offset = 0;
unsigned long lastTime = 0;
void calibrate(int samples = 500);
const float Kp_gyro = 2.0;  // tune this up/down if adjust() overshoots or is too slow
//-----

// sensor readings
float frontDist = 0.0;
float leftDist = 0.0;
float rightDist = 0.0;

// step size
int n = 280;  //30 cm = 500
// turn size
int m = 140;

// 

// front wall dist
const float wallDistThreshold = 4.5;
const float frontWallDistThreshold = 5.0;


void setup() {
  // initialize pins for motors
  pinMode(PWMA, OUTPUT);
  pinMode(AIN1, OUTPUT);
  pinMode(AIN2, OUTPUT);

  pinMode(PWMB, OUTPUT);
  pinMode(BIN1, OUTPUT);
  pinMode(BIN2, OUTPUT);

  // Initialize encoder pins
  pinMode(leftEncoderPhaseA, INPUT);
  pinMode(leftEncoderPhaseB, INPUT);
  pinMode(rightEncoderPhaseA, INPUT);
  pinMode(rightEncoderPhaseB, INPUT);

  // whenever the encoder ticks are rising pause the main code and run counting functions
  attachInterrupt(digitalPinToInterrupt(leftEncoderPhaseA), countLeft, RISING);
  attachInterrupt(digitalPinToInterrupt(rightEncoderPhaseA), countRight, RISING);

  // set up sensors
  sensorFront.setModel(SharpDistSensor::GP2Y0A51SK0F_5V_DS);
  sensorLeft.setModel(SharpDistSensor::GP2Y0A51SK0F_5V_DS);
  sensorRight.setModel(SharpDistSensor::GP2Y0A51SK0F_5V_DS);

  //====

  Serial.begin(9600);
  Wire.begin();
  mpu.initialize();

  if (!mpu.testConnection()) {
    Serial.println("MPU6050 connection failed!");
    while (1);
  }
  calibrate();       // keep robot still during this
  lastTime = millis();

  //====

}


void loop() {
  // put your main code here, to run repeatedly:
  goForward();
  Brake();
  if (frontDist < frontWallDistThreshold) {
    turnLeft(); // Robot spins roughly 90 degrees
    Brake();     // Full stop   
    adjust();
    Brake();
  } 

}

void goForward() {
  
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, LOW);

  digitalWrite(BIN1, HIGH);
  digitalWrite(BIN2, LOW);

  leftTicks = 0;
  rightTicks = 0;

  while (leftTicks < n && rightTicks < n) {

    // GYROO
    updateGyro();
    
    // This part is added for shitty testin
    sensorReadings();
    if (frontDist < frontWallDistThreshold) { 
      break;
    }
    
    float error = centreAdjustment();

    int leftMotorSpeed = speed - error;
    int rightMotorSpeed = speed + error;

    leftMotorSpeed = constrain(leftMotorSpeed, 0, 255);
    rightMotorSpeed = constrain(rightMotorSpeed, 0, 255);

    analogWrite(PWMA, leftMotorSpeed);
    analogWrite(PWMB, rightMotorSpeed);

  }
}
