//-----------------


// adjust by gemini + gyro

void calibrate(int samples = 500) {
  Serial.println("Calibrating... keep robot STILL");
  long sum = 0;
  for (int i = 0; i < samples; i++) {
    int16_t gx, gy, gz;
    mpu.getRotation(&gx, &gy, &gz);
    sum += gz;
    delay(3);
  }
  gyroZ_offset = sum / (float)samples;
  Serial.print("Gyro offset: ");
  Serial.println(gyroZ_offset);
}

// 2. Continuous Background Listener: Tracks running angle in degrees
void updateGyro() {
  int16_t gx, gy, gz;
  mpu.getRotation(&gx, &gy, &gz);

  unsigned long now = millis();
  float dt = (now - lastTime) / 1000.0;
  lastTime = now;

  float gyroZ_dps = (gz - gyroZ_offset) / 131.0;
  if (abs(gyroZ_dps) < 0.5) gyroZ_dps = 0;  // dead zone

  angleZ += gyroZ_dps * dt;
}

// 3. New Math-Based Snap Alignment Function
void adjust() {
  // Find closest 90-degree heading relative to where we booted up
  float targetAngle = round(angleZ / 90.0) * 90.0;
  float angleError = targetAngle - angleZ;

  // Keep spinning on the spot until error drops under 1.0 degree
  while (abs(angleError) > 1.0) {
    updateGyro(); // Keep updating currentAngle dynamically as we move!
    angleError = targetAngle - angleZ;

    int pivotSpeed = angleError * Kp_gyro;
    
    // Motor kick-start: prevent stall near the zero mark
    if (pivotSpeed > 0 && pivotSpeed < 35)  pivotSpeed = 35;
    if (pivotSpeed < 0 && pivotSpeed > -35) pivotSpeed = -35;
    pivotSpeed = constrain(pivotSpeed, -80, 80); 

    if (pivotSpeed > 0) {
      // Pivot counter-clockwise (Left)
      digitalWrite(AIN1, LOW);  digitalWrite(AIN2, HIGH);
      digitalWrite(BIN1, HIGH); digitalWrite(BIN2, LOW);
    } else {
      // Pivot clockwise (Right)
      digitalWrite(AIN1, HIGH); digitalWrite(AIN2, LOW);
      digitalWrite(BIN1, LOW);  digitalWrite(BIN2, HIGH);
    }

    analogWrite(PWMA, abs(pivotSpeed));
    analogWrite(PWMB, abs(pivotSpeed));
  }
  
  Brake(); // Lock wheels once square
}
