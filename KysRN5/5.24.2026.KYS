float centreAdjustment() {
  int adjustment = 0;

  // Both walls are present (Full PID Control)
  if (leftDist < 14.0 && rightDist < 14.0) {
    float error = leftDist - rightDist;

    // 1. Proportional (Current)
    float P = error * Kp;

    // 2. Integral (Past)
    integralError += error;
    // Anti-windup: Don't let the memory build up to dangerous levels
    integralError = constrain(integralError, -50.0, 50.0); 
    float I = integralError * Ki;

    // 3. Derivative (Future)
    float derivative = error - previousError;
    previousError = error; // Save current error for the next loop
    float D = derivative * Kd;

    // The final PID output
    adjustment = P + I + D;
  } 
  
  // Only Right Wall Present
  else if (leftDist == 999 && rightDist < 14.0) {
    float rightWallError = wallDistThreshold - rightDist; 
    adjustment = rightWallError * Kp;
    
    // Reset PID memory so it doesn't ruin the next hallway
    integralError = 0; 
    previousError = 0;
  } 
  
  // Only Left Wall Present
  else if (leftDist < 14.0 && rightDist == 999) {
    float leftWallError = leftDist - wallDistThreshold;
    adjustment = leftWallError * Kp;
    
    // Reset PID memory
    integralError = 0; 
    previousError = 0;
  } 
  
  // No walls
  else {
    adjustment = leftTicks - rightTicks;
    
    // Reset PID memory
    integralError = 0; 
    previousError = 0;
  }

  return adjustment;
}

void sensorReadings() {
  // 1. Create arrays (lists) to hold 5 raw readings each
  float rawFrontList[5];
  float rawLeftList[5];
  float rawRightList[5];

  // 2. Collect 5 readings and append them to the arrays
  for (int i = 0; i < 5; i++) {
    rawFrontList[i] = sensorFront.getDist() / 10.0;
    rawLeftList[i]  = sensorLeft.getDist()  / 10.0;
    rawRightList[i] = sensorRight.getDist() / 10.0;
    
    // Give the IR hardware a micro-moment (1ms) to update its beam between reads
    delay(1); 
  }

  // 3. Sum up all the values in the arrays
  float sumFront = 0.0;
  float sumLeft  = 0.0;
  float sumRight = 0.0;

  for (int i = 0; i < 5; i++) {
    sumFront += rawFrontList[i];
    sumLeft  += rawLeftList[i];
    sumRight += rawRightList[i];
  }

  // 4. Calculate the averages
  float avgFront = sumFront / 5.0;
  float avgLeft  = sumLeft  / 5.0;
  float avgRight = sumRight / 5.0;

  // 5. Map the final averaged values
  frontDist = mapFloat(avgFront, 2.9, 5.6, 4.0, 7.0);
  leftDist  = mapFloat(avgLeft,  3.0, 6.0, 4.0, 7.0);
  rightDist = mapFloat(avgRight, 2.7, 5.1, 3.5, 6.5); //4.0 , 7.0 prev values

  // 6. Set condition for wall to not exist
  if (frontDist > 7.0) { frontDist = 999; }
  if (leftDist > 7.0)  { leftDist = 999;  }
  if (rightDist > 7.0) { rightDist = 999; }
}

float mapFloat(float x, float in_min, float in_max, float out_min, float out_max) {
  return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

void Brake() {
  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, HIGH);

  digitalWrite(BIN1, HIGH);
  digitalWrite(BIN2, HIGH);

  // reset encoder values
  leftTicks = 0;
  rightTicks = 0;

  analogWrite(PWMA, 0);
  analogWrite(PWMB, 0);

  delay(500);
}

// ─── TURN RIGHT ──────────────────────────────────────────
void turnRight() {
  angleZ = 0;  // fresh reference
  lastTime = millis();


  digitalWrite(AIN1, HIGH);
  digitalWrite(AIN2, LOW);
  digitalWrite(BIN1, LOW);
  digitalWrite(BIN2, HIGH);

  leftTicks  = 0;
  rightTicks = 0;

  while (abs(angleZ) < 70.0) {
    updateGyro();

    // slow down in last 20 degrees to avoid overshoot
    float remaining   = 90.0 - angleZ;
    int currentSpeed  = (remaining < 20.0) ? speed / 2 : speed;

    int error = leftTicks - abs(rightTicks);

    int leftMotorSpeed  = constrain(currentSpeed - error, 0, 255);
    int rightMotorSpeed = constrain(currentSpeed + error, 0, 255);

    analogWrite(PWMA, leftMotorSpeed);
    analogWrite(PWMB, rightMotorSpeed);
  }

  Brake();
  angleZ = 0;  // reset for next move
}

// ─── TURN LEFT ───────────────────────────────────────────
void turnLeft() {
  angleZ = 0;  // fresh reference
  lastTime = millis();

  digitalWrite(AIN1, LOW);
  digitalWrite(AIN2, HIGH);
  digitalWrite(BIN1, HIGH);
  digitalWrite(BIN2, LOW);

  leftTicks  = 0;
  rightTicks = 0;

  while (abs(angleZ) < 70.0) {
    updateGyro();

    // slow down in last 20 degrees to avoid overshoot
    float remaining   = 90.0 - abs(angleZ);
    int currentSpeed  = (remaining < 20.0) ? speed / 2 : speed;

    int error = abs(leftTicks) - rightTicks;

    int leftMotorSpeed  = constrain(currentSpeed - error, 0, 255);
    int rightMotorSpeed = constrain(currentSpeed + error, 0, 255);

    analogWrite(PWMA, leftMotorSpeed);
    analogWrite(PWMB, rightMotorSpeed);
  }

  Brake();
  angleZ = 0;  // reset for next move
}


void countLeft() {
  // Check Phase B to see if we are going forward or backward
  if (digitalRead(leftEncoderPhaseB) == HIGH) {
    leftTicks++;
  } else {
    leftTicks--;
  }
}

void countRight() {
  // check if motor spin forward or backward
  if (digitalRead(rightEncoderPhaseB) == HIGH) {
    rightTicks++;
  } else {
    rightTicks--;
  }
}

